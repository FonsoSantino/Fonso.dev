# Database
# For docker-compose, hostname is 'db'
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Generated automatically by config.py if not provided, usually:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/app

# Initial Superuser
FIRST_SUPERUSER=admin@example.com
